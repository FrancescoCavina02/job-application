# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI API key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Model name
# OpenAI examples: gpt-4o, gpt-4o-mini, o1, o3-mini
# Anthropic examples: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-3-5
LLM_MODEL=gpt-4o

# Reasoning effort (for OpenAI o-series models): low, medium, high
LLM_REASONING_EFFORT=medium

# Directory where generated files are saved (default: current working directory)
OUTPUT_DIR=.

# Directory containing your CV source files (default: ./CVs)
CV_DIR=./CVs

# Your personal website URL (included in the LLM prompt)
CANDIDATE_WEBSITE=https://francesco-cavina.netlify.app/

# Port for the local server
PORT=3000

# Set to "true" to fetch sites with expired/invalid TLS certificates (use sparingly).
# Disables cert validation — only use for known sites with broken certs, not unknown URLs.
IGNORE_SSL_ERRORS=false
